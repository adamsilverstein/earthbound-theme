{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Forest Grove",
    "settings": {
        "color": {
            "palette": [
                { "slug": "primary", "color": "#6B8E23", "name": "Olive Drab" },
                { "slug": "secondary", "color": "#2F3D1F", "name": "Dark Forest" },
                { "slug": "tertiary", "color": "#8FBC8F", "name": "Sage" },
                { "slug": "background", "color": "#EFEEE8", "name": "Birch" },
                { "slug": "background-alt", "color": "#E4E3DB", "name": "Birch Dark" },
                { "slug": "foreground", "color": "#1A1C18", "name": "Ink" },
                { "slug": "foreground-muted", "color": "#4E5548", "name": "Moss Grey" },
                { "slug": "accent", "color": "#9ACD32", "name": "Yellow Green" },
                { "slug": "dark", "color": "#151812", "name": "Dark Panel" },
                { "slug": "error", "color": "#8B0000", "name": "Dark Red" },
                { "slug": "success", "color": "#228B22", "name": "Forest Green" }
            ],
            "gradients": [
                {
                    "slug": "warm-sunset",
                    "gradient": "linear-gradient(135deg, #6B8E23 0%, #8FBC8F 100%)",
                    "name": "Forest Canopy"
                },
                {
                    "slug": "earth-tones",
                    "gradient": "linear-gradient(180deg, #EFEEE8 0%, #E4E3DB 100%)",
                    "name": "Birch Fade"
                }
            ]
        },
        "shadow": {
            "presets": [
                {
                    "slug": "natural",
                    "shadow": "0 4px 6px -1px rgba(26, 28, 24, 0.08), 0 2px 4px -1px rgba(26, 28, 24, 0.04)",
                    "name": "Natural"
                },
                {
                    "slug": "warm",
                    "shadow": "0 10px 25px -5px rgba(107, 142, 35, 0.2)",
                    "name": "Forest Glow"
                },
                {
                    "slug": "chunky",
                    "shadow": "4px 4px 0 #2F3D1F",
                    "name": "Chunky"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        }
    }
}
