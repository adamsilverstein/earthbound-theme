{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Desert Sunset",
    "settings": {
        "color": {
            "palette": [
                { "slug": "primary", "color": "#E07B53", "name": "Primary" },
                { "slug": "secondary", "color": "#8B5A2B", "name": "Secondary" },
                { "slug": "tertiary", "color": "#CD853F", "name": "Tertiary" },
                { "slug": "background", "color": "#FFF8F0", "name": "Background" },
                { "slug": "background-alt", "color": "#FFE4C4", "name": "Background Alt" },
                { "slug": "foreground", "color": "#4A3728", "name": "Foreground" },
                { "slug": "foreground-muted", "color": "#7D6B5D", "name": "Foreground Muted" },
                { "slug": "accent", "color": "#D2691E", "name": "Accent" },
                { "slug": "error", "color": "#B22222", "name": "Error" },
                { "slug": "success", "color": "#808000", "name": "Success" }
            ],
            "gradients": [
                {
                    "slug": "warm-sunset",
                    "gradient": "linear-gradient(135deg, #E07B53 0%, #CD853F 100%)",
                    "name": "Warm Sunset"
                },
                {
                    "slug": "earth-tones",
                    "gradient": "linear-gradient(180deg, #FFF8F0 0%, #FFE4C4 100%)",
                    "name": "Earth Tones"
                }
            ]
        },
        "shadow": {
            "presets": [
                {
                    "slug": "natural",
                    "shadow": "0 4px 6px -1px rgba(74, 55, 40, 0.1), 0 2px 4px -1px rgba(74, 55, 40, 0.06)",
                    "name": "Natural"
                },
                {
                    "slug": "warm",
                    "shadow": "0 10px 25px -5px rgba(224, 123, 83, 0.25)",
                    "name": "Warm"
                },
                {
                    "slug": "chunky",
                    "shadow": "4px 4px 0 #8B5A2B",
                    "name": "Chunky"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        }
    }
}
