{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Desert Sunset",
    "settings": {
        "color": {
            "palette": [
                { "slug": "primary", "color": "#E07B53", "name": "Terracotta" },
                { "slug": "secondary", "color": "#4A3020", "name": "Dark Sienna" },
                { "slug": "tertiary", "color": "#CD853F", "name": "Sandy" },
                { "slug": "background", "color": "#F2EDE6", "name": "Parchment" },
                { "slug": "background-alt", "color": "#E8DFD4", "name": "Parchment Dark" },
                { "slug": "foreground", "color": "#1C1816", "name": "Ink" },
                { "slug": "foreground-muted", "color": "#6B5D52", "name": "Warm Grey" },
                { "slug": "accent", "color": "#D2691E", "name": "Burnt Orange" },
                { "slug": "dark", "color": "#1A1510", "name": "Dark Panel" },
                { "slug": "error", "color": "#B22222", "name": "Firebrick" },
                { "slug": "success", "color": "#808000", "name": "Olive" }
            ],
            "gradients": [
                {
                    "slug": "warm-sunset",
                    "gradient": "linear-gradient(135deg, #E07B53 0%, #CD853F 100%)",
                    "name": "Warm Sunset"
                },
                {
                    "slug": "earth-tones",
                    "gradient": "linear-gradient(180deg, #F2EDE6 0%, #E8DFD4 100%)",
                    "name": "Parchment Fade"
                }
            ]
        },
        "shadow": {
            "presets": [
                {
                    "slug": "natural",
                    "shadow": "0 4px 6px -1px rgba(28, 24, 22, 0.08), 0 2px 4px -1px rgba(28, 24, 22, 0.04)",
                    "name": "Natural"
                },
                {
                    "slug": "warm",
                    "shadow": "0 10px 25px -5px rgba(224, 123, 83, 0.2)",
                    "name": "Sunset Glow"
                },
                {
                    "slug": "chunky",
                    "shadow": "4px 4px 0 #4A3020",
                    "name": "Chunky"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        }
    }
}
