{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Harvest Gold",
    "settings": {
        "color": {
            "palette": [
                { "slug": "primary", "color": "#D4A03C", "name": "Amber" },
                { "slug": "secondary", "color": "#3D2B1F", "name": "Dark Brown" },
                { "slug": "tertiary", "color": "#8B7355", "name": "Warm Tan" },
                { "slug": "background", "color": "#F0EDE6", "name": "Newsprint" },
                { "slug": "background-alt", "color": "#E8E4DC", "name": "Newsprint Dark" },
                { "slug": "foreground", "color": "#1A1A1A", "name": "Ink" },
                { "slug": "foreground-muted", "color": "#5C5549", "name": "Warm Grey" },
                { "slug": "accent", "color": "#D4A03C", "name": "Amber Accent" },
                { "slug": "dark", "color": "#1A1712", "name": "Dark Panel" },
                { "slug": "error", "color": "#8B0000", "name": "Dark Red" },
                { "slug": "success", "color": "#556B2F", "name": "Olive" }
            ],
            "gradients": [
                {
                    "slug": "warm-sunset",
                    "gradient": "linear-gradient(135deg, #D4A03C 0%, #8B7355 100%)",
                    "name": "Amber Wash"
                },
                {
                    "slug": "earth-tones",
                    "gradient": "linear-gradient(180deg, #F0EDE6 0%, #E8E4DC 100%)",
                    "name": "Newsprint Fade"
                }
            ]
        },
        "shadow": {
            "presets": [
                {
                    "slug": "natural",
                    "shadow": "0 4px 6px -1px rgba(26, 26, 26, 0.08), 0 2px 4px -1px rgba(26, 26, 26, 0.04)",
                    "name": "Natural"
                },
                {
                    "slug": "warm",
                    "shadow": "0 10px 25px -5px rgba(212, 160, 60, 0.2)",
                    "name": "Amber Glow"
                },
                {
                    "slug": "chunky",
                    "shadow": "4px 4px 0 #3D2B1F",
                    "name": "Chunky"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        }
    }
}
