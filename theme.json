{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "720px",
            "wideSize": "1200px"
        },
        "color": {
            "palette": [
                { "slug": "primary", "color": "#936F26", "name": "Brass" },
                { "slug": "secondary", "color": "#382B1B", "name": "Bistre" },
                { "slug": "tertiary", "color": "#B49C73", "name": "Antique Tan" },
                { "slug": "background", "color": "#ECE2CC", "name": "Parchment" },
                { "slug": "background-alt", "color": "#E5D9BD", "name": "Parchment Shade" },
                { "slug": "foreground", "color": "#2A2218", "name": "Walnut Ink" },
                { "slug": "foreground-muted", "color": "#5B5141", "name": "Warm Grey" },
                { "slug": "accent", "color": "#586736", "name": "Moss" },
                { "slug": "clay", "color": "#A2502A", "name": "Clay" },
                { "slug": "dark", "color": "#1F1A12", "name": "Dark Panel" },
                { "slug": "error", "color": "#9E3B22", "name": "Rust" },
                { "slug": "success", "color": "#4F6B33", "name": "Moss Green" }
            ],
            "gradients": [
                {
                    "slug": "warm-sunset",
                    "gradient": "linear-gradient(155deg, #E4CB8B 0%, #B6912F 38%, #836321 70%, #C9AC68 100%)",
                    "name": "Brass Patina"
                },
                {
                    "slug": "earth-tones",
                    "gradient": "linear-gradient(180deg, var(--wp--preset--color--background) 0%, var(--wp--preset--color--background-alt) 100%)",
                    "name": "Earth Tones"
                }
            ],
            "custom": true,
            "customDuotone": true,
            "customGradient": true,
            "defaultPalette": false,
            "defaultGradients": false
        },
        "typography": {
            "fluid": true,
            "fontFamilies": [
                {
                    "fontFamily": "'Playfair Display', Georgia, serif",
                    "slug": "heading",
                    "name": "Heading",
                    "fontFace": [
                        {
                            "fontFamily": "Playfair Display",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/playfair-display-v40-latin-regular.woff2"]
                        },
                        {
                            "fontFamily": "Playfair Display",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/playfair-display-v40-latin-700.woff2"]
                        },
                        {
                            "fontFamily": "Playfair Display",
                            "fontWeight": "400",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/playfair-display-v40-latin-italic.woff2"]
                        },
                        {
                            "fontFamily": "Playfair Display",
                            "fontWeight": "700",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/playfair-display-v40-latin-700italic.woff2"]
                        }
                    ]
                },
                {
                    "fontFamily": "'Hanken Grotesk', system-ui, -apple-system, 'Segoe UI', sans-serif",
                    "slug": "body",
                    "name": "Body",
                    "fontFace": [
                        {
                            "fontFamily": "Hanken Grotesk",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/hanken-grotesk-v12-latin-regular.woff2"]
                        },
                        {
                            "fontFamily": "Hanken Grotesk",
                            "fontWeight": "500",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/hanken-grotesk-v12-latin-500.woff2"]
                        },
                        {
                            "fontFamily": "Hanken Grotesk",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/hanken-grotesk-v12-latin-600.woff2"]
                        },
                        {
                            "fontFamily": "Hanken Grotesk",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/hanken-grotesk-v12-latin-700.woff2"]
                        }
                    ]
                },
                {
                    "fontFamily": "Lora, Georgia, serif",
                    "slug": "serif",
                    "name": "Serif",
                    "fontFace": [
                        {
                            "fontFamily": "Lora",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/lora-v37-latin-regular.woff2"]
                        },
                        {
                            "fontFamily": "Lora",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/lora-v37-latin-700.woff2"]
                        },
                        {
                            "fontFamily": "Lora",
                            "fontWeight": "400",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/lora-v37-latin-italic.woff2"]
                        },
                        {
                            "fontFamily": "Lora",
                            "fontWeight": "700",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/lora-v37-latin-700italic.woff2"]
                        }
                    ]
                },
                {
                    "fontFamily": "'Space Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
                    "slug": "mono",
                    "name": "Monospace",
                    "fontFace": [
                        {
                            "fontFamily": "Space Mono",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/space-mono-v15-latin-regular.woff2"]
                        },
                        {
                            "fontFamily": "Space Mono",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/space-mono-v15-latin-700.woff2"]
                        }
                    ]
                },
                {
                    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
                    "slug": "system",
                    "name": "System"
                }
            ],
            "fontSizes": [
                { "slug": "small", "size": "0.875rem", "fluid": { "min": "0.75rem", "max": "0.875rem" } },
                { "slug": "medium", "size": "1.125rem", "fluid": { "min": "1rem", "max": "1.125rem" } },
                { "slug": "large", "size": "1.375rem", "fluid": { "min": "1.125rem", "max": "1.375rem" } },
                { "slug": "x-large", "size": "2.25rem", "fluid": { "min": "1.5rem", "max": "2.25rem" } },
                { "slug": "xx-large", "size": "3.5rem", "fluid": { "min": "2rem", "max": "3.5rem" } },
                { "slug": "hero", "size": "6rem", "fluid": { "min": "3rem", "max": "6rem" } }
            ],
            "customFontSize": true,
            "lineHeight": true,
            "dropCap": true
        },
        "spacing": {
            "units": ["rem", "em", "%", "vw"],
            "spacingScale": {
                "steps": 7
            },
            "blockGap": true,
            "margin": true,
            "padding": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "shadow": {
            "presets": [
                {
                    "slug": "natural",
                    "shadow": "0 2px 0 rgba(111, 83, 24, 0.10), 0 6px 16px rgba(42, 34, 24, 0.14)",
                    "name": "Natural"
                },
                {
                    "slug": "warm",
                    "shadow": "0 10px 25px -5px rgba(147, 111, 38, 0.22)",
                    "name": "Brass Lift"
                },
                {
                    "slug": "chunky",
                    "shadow": "4px 4px 0 var(--wp--preset--color--secondary)",
                    "name": "Chunky"
                }
            ]
        },
        "custom": {
            "borderRadius": {
                "small": "0.125rem",
                "medium": "0.25rem",
                "large": "0.4375rem",
                "pill": "9999px"
            },
            "transition": {
                "fast": "150ms ease",
                "normal": "250ms ease",
                "slow": "400ms ease"
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--body)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.6"
        },
        "spacing": {
            "blockGap": "1.5rem",
            "padding": {
                "top": "0",
                "right": "clamp(1rem, 5vw, 2rem)",
                "bottom": "0",
                "left": "clamp(1rem, 5vw, 2rem)"
            }
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)",
                    "fontWeight": "700",
                    "lineHeight": "1.15"
                },
                "color": {
                    "text": "var(--wp--preset--color--secondary)"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--hero)"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xx-large)"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--x-large)"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--large)"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--secondary)"
                    }
                },
                ":focus": {
                    "color": {
                        "text": "var(--wp--preset--color--secondary)"
                    }
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--background)"
                },
                "border": {
                    "radius": "var(--wp--custom--border-radius--medium)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)",
                    "fontSize": "var(--wp--preset--font-size--medium)",
                    "fontWeight": "700"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--secondary)"
                    }
                },
                ":focus": {
                    "color": {
                        "background": "var(--wp--preset--color--secondary)"
                    }
                }
            }
        },
        "blocks": {
            "core/site-title": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)",
                    "fontSize": "var(--wp--preset--font-size--x-large)"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--secondary)"
                        },
                        ":hover": {
                            "color": {
                                "text": "var(--wp--preset--color--primary)"
                            }
                        }
                    }
                }
            },
            "core/navigation": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--foreground)"
                        },
                        ":hover": {
                            "color": {
                                "text": "var(--wp--preset--color--primary)"
                            }
                        }
                    }
                }
            },
            "core/post-title": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--heading)"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var(--wp--preset--color--secondary)"
                        },
                        ":hover": {
                            "color": {
                                "text": "var(--wp--preset--color--primary)"
                            }
                        }
                    }
                }
            },
            "core/quote": {
                "border": {
                    "left": {
                        "color": "var(--wp--preset--color--primary)",
                        "width": "4px"
                    }
                },
                "spacing": {
                    "padding": {
                        "left": "1.5rem"
                    }
                },
                "color": {
                    "text": "var(--wp--preset--color--foreground-muted)"
                }
            },
            "core/code": {
                "color": {
                    "background": "var(--wp--preset--color--background-alt)",
                    "text": "var(--wp--preset--color--foreground)"
                },
                "border": {
                    "radius": "var(--wp--custom--border-radius--small)"
                },
                "spacing": {
                    "padding": {
                        "top": "1rem",
                        "right": "1.5rem",
                        "bottom": "1rem",
                        "left": "1.5rem"
                    }
                }
            }
        }
    },
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" },
        { "name": "sidebar", "title": "Sidebar", "area": "uncategorized" }
    ],
    "customTemplates": [
        { "name": "page-my-work", "title": "My Work", "postTypes": ["page"] },
        { "name": "blank", "title": "Blank Canvas", "postTypes": ["page", "post"] }
    ]
}
