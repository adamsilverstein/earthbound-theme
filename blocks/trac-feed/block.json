{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "earthbound/trac-feed",
    "version": "1.0.0",
    "title": "Trac Feed",
    "category": "earthbound",
    "icon": "wordpress",
    "description": "Display WordPress Trac contributions.",
    "keywords": ["trac", "wordpress", "core", "contributions"],
    "textdomain": "earthbound",
    "supports": {
        "html": false,
        "className": true,
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "padding": true,
            "margin": true
        },
        "interactivity": true
    },
    "attributes": {
        "perPage": {
            "type": "number",
            "default": 10
        }
    },
    "viewScriptModule": "file:./view.js",
    "style": "file:./style.css",
    "render": "file:./render.php"
}
